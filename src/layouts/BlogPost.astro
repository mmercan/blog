---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        --color-text: #1a1a1a;
        --color-muted: #666;
        --color-accent: #6c4bf4;
        --color-bg: #fff;
        --color-border: #e5e5e5;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-serif: Georgia, 'Times New Roman', serif;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: var(--font-serif);
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.8;
        font-size: 1.125rem;
      }

      header {
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 0;
        margin-bottom: 3rem;
      }

      header nav {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      header nav a {
        font-family: var(--font-sans);
        font-weight: 600;
        color: var(--color-text);
        text-decoration: none;
        font-size: 1.1rem;
      }

      article {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 1.5rem 4rem;
      }

      .post-header { margin-bottom: 2.5rem; }

      h1 {
        font-family: var(--font-sans);
        font-size: 2.25rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
      }

      .meta {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        color: var(--color-muted);
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
      }

      .tag {
        background: #f3f0ff;
        color: var(--color-accent);
        font-size: 0.78rem;
        font-weight: 600;
        padding: 0.2rem 0.6rem;
        border-radius: 99px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        text-decoration: none;
      }

      .prose h2 { font-family: var(--font-sans); font-size: 1.5rem; font-weight: 700; margin: 2.5rem 0 1rem; }
      .prose h3 { font-family: var(--font-sans); font-size: 1.25rem; font-weight: 700; margin: 2rem 0 0.75rem; }
      .prose p { margin-bottom: 1.5rem; }
      .prose a { color: var(--color-accent); }
      .prose code {
        font-size: 0.9em;
        background: #f5f5f5;
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-family: 'Fira Code', 'Cascadia Code', monospace;
      }
      .prose pre {
        background: #1e1e2e;
        color: #cdd6f4;
        padding: 1.25rem 1.5rem;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        line-height: 1.6;
      }
      .prose pre code { background: none; padding: 0; }
      .prose blockquote {
        border-left: 3px solid var(--color-accent);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: var(--color-muted);
        font-style: italic;
      }
      .prose ul, .prose ol { padding-left: 1.5rem; margin-bottom: 1.5rem; }
      .prose li { margin-bottom: 0.4rem; }
      .prose hr { border: none; border-top: 1px solid var(--color-border); margin: 2.5rem 0; }
      .prose img { max-width: 100%; border-radius: 8px; margin: 1.5rem 0; }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">My Blog</a>
        <a href="/blog">All Posts</a>
      </nav>
    </header>

    <article>
      <div class="post-header">
        <h1>{title}</h1>
        <div class="meta">
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          {updatedDate && <span>· Updated {formattedUpdatedDate}</span>}
          {tags.length > 0 && (
            <div class="tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </div>

      <div class="prose">
        <slot />
      </div>
    </article>
  </body>
</html>
